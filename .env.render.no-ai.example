# Render env template (NO-AI) for aitoearn-server

NODE_ENV=production
APP_ENV=production
APP_NAME=aitoearn-server
APP_DOMAIN=api.yourdomain.com

JWT_SECRET=replace-me
INTERNAL_TOKEN=replace-me

# External database/cache
MONGODB_URI=mongodb+srv://USER:PASS@cluster.example.mongodb.net/aitoearn?retryWrites=true&w=majority
MONGODB_CHANNEL_URI=
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_HOST:6379
REDIS_TLS=true

# Cloudflare R2 (one-line JSON)
ASSETS_CONFIG={"provider":"s3","region":"auto","bucketName":"aitoearn","endpoint":"https://<account>.r2.cloudflarestorage.com","publicEndpoint":"https://<public-domain>","cdnEndpoint":"https://<cdn-domain>","accessKeyId":"<access-key>","secretAccessKey":"<secret>","forcePathStyle":true}

# No-AI mode
AI_URL=http://127.0.0.1:3010

# Optional
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_FROM="AiToEarn <noreply@yourdomain.com>"
MAIL_USER=resend
MAIL_PASS=
RELAY_SERVER_URL=https://aitoearn.ai/api
RELAY_API_KEY=
RELAY_CALLBACK_URL=https://api.yourdomain.com/api/plat/relay-callback
